# Azure Speech
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# Google / Vertex AI
GOOGLE_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=europe-west1
GOOGLE_CREDENTIALS_JSON=   # paste the full service-account JSON as a single line

# Database (Railway sets this automatically when you add a Postgres service)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_ID=
